# Week 3 - Task 29: NumPy Array Indexing
# https://www.w3schools.com/python/numpy_array_indexing.asp

import numpy as np

def main():
    arr1 = np.array([10, 20, 30, 40])
    print("arr1:", arr1)
    print("arr1[0]:", arr1[0])
    print("arr1[-1]:", arr1[-1])

    arr2 = np.array([[1, 2, 3], [4, 5, 6]])
    print("\narr2:\n", arr2)
    print("arr2[0, 1] (row0 col1):", arr2[0, 1])
    print("arr2[1, 2] (row1 col2):", arr2[1, 2])

    arr3 = np.array([[[1, 2], [3, 4]], [[5, 6], [7, 8]]])
    print("\narr3:\n", arr3)
    print("arr3[1, 0, 1]:", arr3[1, 0, 1])  # 6

if __name__ == "__main__":
    main()
